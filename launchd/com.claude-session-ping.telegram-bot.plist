<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude-session-ping.telegram-bot</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>python3</string>
    <string>{{PROJECT_DIR}}/scripts/telegram_qa_daemon.py</string>
  </array>

  <!-- launchd's default PATH is /usr/bin:/bin:/usr/sbin:/sbin, which does not
       include claude's install dir, so the daemon's /usage lookup silently
       fell back to the schedule. USER/LOGNAME keep `claude` logged in. -->
  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>{{HOME_DIR}}/.local/bin:/usr/local/bin:/opt/homebrew/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    <key>USER</key>
    <string>{{USER}}</string>
    <key>LOGNAME</key>
    <string>{{USER}}</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>{{PROJECT_DIR}}/logs/claude-session-ping-telegram-bot.out.log</string>

  <key>StandardErrorPath</key>
  <string>{{PROJECT_DIR}}/logs/claude-session-ping-telegram-bot.err.log</string>
</dict>
</plist>
