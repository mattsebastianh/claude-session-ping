<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.claude-session-ping.telegram-bot</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/bin/env</string>
    <string>python3</string>
    <string>{{PROJECT_DIR}}/scripts/telegram_qa_daemon.py</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>{{HOME_DIR}}/Library/Logs/claude-session-ping-telegram-bot.out.log</string>

  <key>StandardErrorPath</key>
  <string>{{HOME_DIR}}/Library/Logs/claude-session-ping-telegram-bot.err.log</string>
</dict>
</plist>
