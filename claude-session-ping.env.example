# claude-session-ping.env.example
#
# Optional configuration for scripts/claude_session_ping.sh.
# The script works out of the box with no config file at all (it just
# calls `claude -p` directly). Use this file only if you want to override
# that default behavior: send the ping elsewhere, customize the message,
# or fake the current time for testing.
#
# Copy this file to ~/.claude-session-ping.env and uncomment/adjust what you need.

# Example: use the Claude CLI directly.
# CLAUDE_SESSION_PING_COMMAND='claude --print "keepalive ping"'

# Or send to an HTTP endpoint instead.
# CLAUDE_SESSION_PING_URL='https://example.com/claude-ping'

# Optional message body.
# CLAUDE_SESSION_PING_MESSAGE='keepalive ping'

# Optional: override the current time for testing.
# Example: test the 11:11 trigger without waiting for real time.
# CLAUDE_SESSION_PING_MOCK_TIME='11:11'
